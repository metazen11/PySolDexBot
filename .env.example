# Network Settings
SOLANA_RPC_URL=your_rpc_url
NETWORK=mainnet  # or devnet

# Wallet Settings
WALLET_PRIVATE_KEY=your_private_key

# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=soldexbot
DB_USER=your_username
DB_PASSWORD=your_password
DB_ECHO=False  # Set to True for SQL query logging
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# API Keys
HELIUS_API_KEY=your_helius_key
DEXSCREENER_API_KEY=your_dexscreener_key
BIRDEYE_API_KEY=your_birdeye_key

# Honeypot Detection
MIN_SELL_COUNT=5
MIN_UNIQUE_SELLERS=3
MAX_TAX_PERCENTAGE=10
MIN_SUCCESSFUL_SELLS=3
MIN_LP_LOCK_DAYS=30
MAX_LP_HOLDER_PERCENTAGE=80
MIN_SUCCESSFUL_TXN_RATIO=0.9

# Trading Parameters
SLIPPAGE=0.5
MAX_SLIPPAGE=1.0
CHECK_INTERVAL=60  # Seconds between checks

# Technical Analysis Parameters
BUY_ADX_THRESHOLD=25
BUY_RSI_THRESHOLD=30
SELL_RSI_THRESHOLD=70
MOMENTUM_PERIOD=10
ADX_PERIOD=14
RSI_PERIOD=14

# Token Filtering
MIN_LIQUIDITY_USD=50000
MIN_HOLDERS=200
MIN_AGE_DAYS=3
MIN_VOLUME_24H=10000

# Risk Management
MAX_POSITION_SIZE=0.1  # 10% of portfolio
STOP_LOSS_PERCENTAGE=2.0
TAKE_PROFIT_PERCENTAGE=4.0
RISK_PER_TRADE=0.02  # 2% risk per trade

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FILE=bot.log  # Leave empty for console only

# Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
DISCORD_WEBHOOK_URL=your_discord_webhook